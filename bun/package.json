{
  "name": "harness",
  "version": "0.1.0",
  "description": "Bun project template with built-in harness: linting, formatting, type-checking, and testing.",
  "scripts": {
    "check": "bun harness.ts check",
    "fix": "bun harness.ts fix",
    "lint": "bunx biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "acceptance": "bun harness.ts acceptance",
    "coverage": "bun harness.ts coverage",
    "mutation": "bun harness.ts mutation",
    "crap": "bun harness.ts crap",
    "arch": "bun harness.ts arch",
    "pre-commit": "bun harness.ts pre-commit",
    "ci": "bun harness.ts ci",
    "setup-hooks": "bun harness.ts setup-hooks",
    "clean": "bun harness.ts clean"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@biomejs/biome": "^2.5.1",
    "@cucumber/cucumber": "^12.9.0",
    "@stryker-mutator/core": "^9.6.1",
    "dependency-cruiser": "^17.4.0",
    "fast-check": "^4.0.0",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "qs": "6.15.2"
  }
}
